{
  "name": "agentpack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "cli": "node dist/apps/cli/src/index.js",
    "schemas": "node dist/apps/cli/src/index.js schemas",
    "validate:cam": "node dist/apps/cli/src/index.js validate packages/test-fixtures/fixtures/minimal-cam.json --kind cam",
    "test": "node dist/tests/phase1-foundation.test.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
